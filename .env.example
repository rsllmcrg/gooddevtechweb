# Environment variable template — names only, NO real values or secrets.
# Copy to `.env.local` for local development and fill in real values there.
# `.env.local` is gitignored; this file is committed so the required names
# are documented. In Vercel, set these under Project → Settings →
# Environment Variables, scoped per environment (Production / Preview / Development).

# Public canonical origin of the site. Used to build absolute URLs for
# metadata (Open Graph, canonical links). Must be prefixed NEXT_PUBLIC_ to be
# readable in the browser; it is inlined at build time.
#   Production: https://gooddevtech.com  (your production domain)
#   Preview:    leave unset to fall back, or set a staging URL
#   Local:      http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://gooddevtechweb.vercel.app/
