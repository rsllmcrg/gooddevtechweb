# Environment variable template — names only, NO real values or secrets.
# Copy to `.env.local` for local development and fill in real values there.
# `.env.local` is gitignored; this file is committed so the required names
# are documented. In Vercel, set these under Project → Settings →
# Environment Variables, scoped per environment (Production / Preview / Development).

# Public canonical origin of the site. Used to build absolute URLs for
# metadata (Open Graph, canonical links). Must be prefixed NEXT_PUBLIC_ to be
# readable in the browser; it is inlined at build time.
#   Production: https://gooddevtech.com  (your production domain)
#   Preview:    leave unset to fall back, or set a staging URL
#   Local:      http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://gooddevtechweb.vercel.app/

# Postgres connection string for the contact-form submissions table
# (lib/db/index.ts, schema in lib/db/schema.sql). Any standard Postgres
# works — Neon and Vercel Postgres both give you this string directly.
# Apply the schema once with `npm run db:migrate` after setting this.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Resend API key for sending the contact-form notification email
# (lib/email.ts). Get one at https://resend.com/api-keys — the free tier
# works fine to start, and needs no domain verification if you use the
# default CONTACT_FROM_EMAIL below.
RESEND_API_KEY=re_your_api_key

# Inbox the contact-form notification email is sent to.
CONTACT_TO_EMAIL=hello@example.com

# Sender address for that notification. Defaults to Resend's shared
# sending domain (works immediately, no DNS setup) if left unset — swap in
# an address on a domain you've verified with Resend once one exists.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Shared secret for retrieving stored submissions via
# GET /api/contact (Authorization: Bearer <this value>). Generate one
# with `openssl rand -hex 32` — never reuse it anywhere else.
ADMIN_API_TOKEN=generate-a-long-random-value
